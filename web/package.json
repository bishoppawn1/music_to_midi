{
  "name": "link-to-midi-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "vite --config vite.pages.config.ts",
    "build": "npm run build:pages",
    "build:pages": "node scripts/clean-pages-assets.mjs && vite build --config vite.pages.config.ts",
    "test": "npm run build:pages && node --test tests/pages-build.test.mjs && node --experimental-strip-types --test tests/*.test.ts",
    "lint": "tsc --noEmit --incremental false && eslint app static-site tests scripts vite.pages.config.ts"
  },
  "dependencies": {
    "@spotify/basic-pitch": "^1.0.1",
    "@tonejs/midi": "^2.0.28",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "9.39.4",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "8.0.13"
  },
  "type": "module"
}
